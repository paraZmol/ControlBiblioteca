<Window x:Class="ControlBiblioteca.Client.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Control Biblioteca UNASAM"
        WindowStyle="None"
        WindowState="Normal"
        Topmost="True"
        ResizeMode="NoResize"
        AllowsTransparency="False">

    <Window.Background>
        <ImageBrush ImageSource="pack://application:,,,/images/fondo_3.png"
                    Stretch="UniformToFill"
                    AlignmentX="Center"
                    AlignmentY="Center"
                    Opacity="0.55"/>
    </Window.Background>

    <!-- ── Estilos globales ────────────────────────────────────────── -->
    <Window.Resources>
        <!-- TextBox moderno -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="#2B2D42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#8D99AE"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Stretch"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox moderno -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="#2B2D42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#8D99AE"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"/>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid>
                                            <Border Background="Transparent"/>
                                            <Path x:Name="Arrow"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,12,0"
                                                  Fill="#8D99AE"
                                                  Data="M 0 0 L 6 6 L 12 0 Z"/>
                                        </Grid>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                        Background="#2B2D42"
                                        BorderBrush="#8D99AE"
                                        BorderThickness="1"
                                        CornerRadius="0,0,6,6"
                                        MaxHeight="300"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem moderno -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3D405B"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#e94560"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón moderno -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#e94560"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#d63651"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#c12a45"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#555"/>
                                <Setter Property="Foreground" Value="#999"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Overlay oscuro sobre la imagen de fondo para legibilidad -->
        <Rectangle Fill="#CC0f0f23" Panel.ZIndex="0"/>

        <Grid Panel.ZIndex="1">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Panel de bloqueo (visible cuando está bloqueado) -->
        <StackPanel x:Name="PanelBloqueo" Grid.Row="1" 
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="Visible">
            
            <!-- Logo / Título -->
            <TextBlock Text="📚 Biblioteca UNASAM" 
                       FontSize="36" FontWeight="Bold" 
                       Foreground="#e94560" HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>
            
            <TextBlock x:Name="TxtNombreEquipo"
                       Text="Equipo: —"
                       FontSize="16" Foreground="#9ca3af"
                       HorizontalAlignment="Center" Margin="0,4,0,36"/>

            <!-- Campo de código -->
            <TextBlock Text="Ingrese su número de DNI:"
                       FontSize="16" Foreground="White"
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <TextBox x:Name="TxtCodigo"
                     Width="300" Height="45" FontSize="20"
                     HorizontalAlignment="Center"
                     HorizontalContentAlignment="Center"
                     MaxLength="8"
                     Style="{StaticResource ModernTextBox}"
                     KeyDown="TxtCodigo_KeyDown"/>

            <!-- Razón de uso -->
            <TextBlock Text="Razón de uso:"
                       FontSize="16" Foreground="White"
                       HorizontalAlignment="Center" Margin="0,20,0,5"/>

            <ComboBox x:Name="CmbRazon"
                      Width="300" Height="40"
                      HorizontalAlignment="Center"
                      Style="{StaticResource ModernComboBox}"
                      SelectionChanged="CmbRazon_SelectionChanged">
                <ComboBoxItem Content="Investigación" IsSelected="True"/>
                <ComboBoxItem Content="Lectura de libros digitales"/>
                <ComboBoxItem Content="Uso de base de datos"/>
                <ComboBoxItem Content="Trabajos académicos"/>
                <ComboBoxItem Content="Uso de AutoCAD y/o Civil 3D"/>
                <ComboBoxItem Content="Clases virtuales"/>
                <ComboBoxItem Content="Otros (Especificar)"/>
            </ComboBox>

            <!-- Campo para especificar "Otros" -->
            <Grid x:Name="PanelOtros" Width="300" Margin="0,8,0,0"
                  HorizontalAlignment="Center" Visibility="Collapsed">
                <TextBox x:Name="TxtOtroRazon"
                         Height="38" FontSize="14"
                         Style="{StaticResource ModernTextBox}"
                         MaxLength="100"
                         TextChanged="TxtOtroRazon_TextChanged"/>
                <!-- Placeholder visual -->
                <TextBlock x:Name="PlaceholderOtros"
                           Text="Especifique la razón..."
                           FontSize="14" Foreground="#666"
                           IsHitTestVisible="False"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>
            </Grid>

            <!-- Texto de error para "Otros" vacío -->
            <TextBlock x:Name="TxtErrorOtros" Text=""
                       FontSize="12" Foreground="#ff6b6b"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>

            <Button x:Name="BtnIngresar" Content="INGRESAR" 
                    Width="300" Height="45"
                    Margin="0,15,0,0"
                    Style="{StaticResource ModernButton}"
                    Click="BtnIngresar_Click"/>

            <!-- Mensaje de estado -->
            <TextBlock x:Name="TxtEstado" Text="" 
                       FontSize="14" Foreground="#ffc947"
                       HorizontalAlignment="Center" Margin="0,20,0,0"
                       TextWrapping="Wrap" MaxWidth="400"/>
            
            <!-- Estado de conexión -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                <Ellipse x:Name="IndicadorConexion" Width="10" Height="10" 
                         Fill="Red" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtConexion" Text="Desconectado" 
                           FontSize="12" Foreground="#888"/>
            </StackPanel>
        </StackPanel>

        <!-- Panel de sesión activa (visible cuando está desbloqueado) -->
        <StackPanel x:Name="PanelSesion" Grid.Row="1"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="Collapsed">
            
            <TextBlock Text="✅ Sesión Activa" 
                       FontSize="28" FontWeight="Bold"
                       Foreground="#0f3460" HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <TextBlock x:Name="TxtBienvenida" Text="" 
                       FontSize="20" Foreground="White"
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <TextBlock x:Name="TxtInfoAlumno" Text="" 
                       FontSize="14" Foreground="#aaa"
                       HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <Button x:Name="BtnCerrarSesion" Content="CERRAR SESIÓN" 
                    Width="250" Height="40"
                    Style="{StaticResource ModernButton}"
                    Click="BtnCerrarSesion_Click"/>
        </StackPanel>
        <!-- Consola de depuración (fila inferior) -->
        <Border Grid.Row="3" Background="#0a0a1a" BorderBrush="#333" BorderThickness="0,1,0,0">
            <ScrollViewer x:Name="DebugScroll"
                          MaxHeight="120" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Padding="8,4">
                <TextBlock x:Name="TxtDebug"
                           FontFamily="Consolas, Courier New" FontSize="11"
                           Foreground="#5af78e" TextWrapping="NoWrap"
                           VerticalAlignment="Top"/>
            </ScrollViewer>
        </Border>
        </Grid><!-- fin inner Grid con contenido -->
    </Grid>
</Window>
