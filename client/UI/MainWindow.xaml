<Window x:Class="ControlBiblioteca.Client.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Control Biblioteca UNASAM"
        WindowStyle="None"
        WindowState="Normal"
        Topmost="True"
        ResizeMode="NoResize"
        AllowsTransparency="False"
        FocusManager.FocusedElement="{Binding ElementName=TxtCodigo}">

    <Window.Background>
        <ImageBrush ImageSource="pack://application:,,,/images/fondo_3.png"
                    Stretch="UniformToFill"
                    AlignmentX="Center"
                    AlignmentY="Center"/>
    </Window.Background>

    <!-- ── Recursos / Estilos ────────────────────────────────────────── -->
    <Window.Resources>
        <!-- TextBox glass — estilo nuevo -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="#14FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#28FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#00B4DB"/>
                                <Setter Property="Background"  Value="#1EFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox glass -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="#14FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#28FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"/>
                            <ToggleButton x:Name="ToggleButton" Focusable="False"
                                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid Background="Transparent">
                                            <Path x:Name="Arrow" HorizontalAlignment="Right"
                                                  VerticalAlignment="Center" Margin="0,0,14,0"
                                                  Fill="#8D99AE" Data="M 0 0 L 6 6 L 12 0 Z"/>
                                        </Grid>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="True" PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder" Background="#1E293B"
                                        BorderBrush="#334155" BorderThickness="1"
                                        CornerRadius="0,0,10,10" MaxHeight="300"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1EFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#00B4DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón gradiente cyan UNASAM -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" CornerRadius="10" Padding="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#00B4DB" Offset="0"/>
                                    <GradientStop Color="#0083B0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BtnBorder" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón cerrar sesión (rojo) -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="#e94560" CornerRadius="10" Padding="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#c73a52"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#a82d43"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid IsHitTestVisible="True">

        <!-- ══ COMUNICADO: carrusel para alumno no registrado ══ -->
        <Grid x:Name="PanelComunicado" Panel.ZIndex="10"
              Visibility="Collapsed"
              Background="#99000000">

            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    CornerRadius="20" Width="960" MaxHeight="780"
                    BorderThickness="1">
                <Border.Background>
                    <SolidColorBrush Color="#CC0F1A2E"/>
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="#5500B4DB"/>
                </Border.BorderBrush>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" ShadowDepth="0" Color="#AA000000"/>
                </Border.Effect>

                <Grid Margin="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Imagen activa (Contain/Fit) -->
                    <Grid Grid.Row="0" ClipToBounds="True" MinHeight="520">
                        <Image x:Name="ImgComunicado0"
                               Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="16"/>
                        <Image x:Name="ImgComunicado1"
                               Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="16" Visibility="Collapsed"/>

                        <!-- Flecha izquierda -->
                        <Button x:Name="BtnCarruselIzq" Content="❮"
                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                Margin="10,0,0,0" Width="42" Height="42"
                                FontSize="18" FontWeight="Bold"
                                Foreground="White" Background="#55000000"
                                BorderThickness="0" Cursor="Hand"
                                Click="BtnCarruselIzq_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            CornerRadius="21">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#AA00B4DB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Flecha derecha -->
                        <Button x:Name="BtnCarruselDer" Content="❯"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Margin="0,0,10,0" Width="42" Height="42"
                                FontSize="18" FontWeight="Bold"
                                Foreground="White" Background="#55000000"
                                BorderThickness="0" Cursor="Hand"
                                Click="BtnCarruselDer_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            CornerRadius="21">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#AA00B4DB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- Dots indicadores -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,10,0,6">
                        <Ellipse x:Name="Dot0" Width="10" Height="10" Margin="5,0"
                                 Fill="#00B4DB"/>
                        <Ellipse x:Name="Dot1" Width="10" Height="10" Margin="5,0"
                                 Fill="#44FFFFFF"/>
                    </StackPanel>

                    <!-- Botón cerrar -->
                    <Button Grid.Row="2" Content="Cerrar Comunicado"
                            Height="46" Margin="40,4,40,20"
                            Style="{StaticResource ModernButton}"
                            Click="BtnCerrarComunicado_Click"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Panel.ZIndex="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ══ PANEL DE BLOQUEO (pantalla de login del alumno) ══ -->
            <StackPanel x:Name="PanelBloqueo" Grid.Row="1"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="Visible" Width="360">

                <!-- Logo / Identidad -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24" IsHitTestVisible="False">
                    <!-- Escudo UNASAM — equivalente al SVG del panel web -->
                    <Border Width="76" Height="76" CornerRadius="18" HorizontalAlignment="Center"
                            Margin="0,0,0,14" IsHitTestVisible="False">
                        <Border.Background>
                            <SolidColorBrush Color="#1A00B4DB"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#4400B4DB"/>
                        </Border.BorderBrush>
                        <Border.BorderThickness>1</Border.BorderThickness>
                        <Viewbox Width="46" Height="46" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <!-- Escudo -->
                                <Path Data="M12 2L3 7V12C3 17.5 7 21 12 22C17 21 21 17.5 21 12V7L12 2Z"
                                      Stroke="#00B4DB" StrokeThickness="2">
                                    <Path.Fill>
                                        <SolidColorBrush Color="#1A00B4DB"/>
                                    </Path.Fill>
                                </Path>
                                <!-- Reloj -->
                                <Path Data="M12 6V12L16 14"
                                      Stroke="#00B4DB" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="Biblioteca UNASAM"
                               FontSize="26" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TxtNombreEquipo" Text="Equipo: —"
                               FontSize="11" FontWeight="SemiBold" Foreground="#00B4DB"
                               HorizontalAlignment="Center"                               TextOptions.TextFormattingMode="Display"/>
                </StackPanel>

                <!-- Tarjeta login — rgba(40,40,45,0.85) -->
                <!-- Sombra exterior sin DropShadowEffect para no bloquear hit-test -->
                <Border CornerRadius="22" Margin="4,4,4,4" Padding="1" IsHitTestVisible="False">
                    <Border.Background>
                        <SolidColorBrush Color="#55000000"/>
                    </Border.Background>
                </Border>
                <Border CornerRadius="20" Padding="32,28"
                        IsHitTestVisible="True">
                    <Border.Background>
                        <SolidColorBrush Color="#D928282D"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#40FFFFFF"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>

                    <StackPanel IsHitTestVisible="True">
                        <!-- DNI -->
                        <TextBlock Text="NÚMERO DE DNI" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#94A3B8"                                   Margin="2,0,0,8"/>
                        <TextBox x:Name="TxtCodigo"
                                 Height="48" FontSize="18"
                                 HorizontalContentAlignment="Left"
                                 MaxLength="8"
                                 Style="{StaticResource ModernTextBox}"
                                 KeyDown="TxtCodigo_KeyDown"
                                 TextChanged="TxtCodigo_TextChanged"
                                 PreviewTextInput="TxtCodigo_PreviewTextInput"
                                 DataObject.Pasting="TxtCodigo_Pasting"
                                 Margin="0,0,0,18"
                                 Focusable="True"
                                 IsTabStop="True"
                                 TabIndex="1"/>

                        <!-- Razón -->
                        <TextBlock Text="RAZÓN DE USO" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#94A3B8"                                   Margin="2,0,0,8"/>
                        <ComboBox x:Name="CmbRazon"
                                  Height="48"
                                  Style="{StaticResource ModernComboBox}"
                                  SelectionChanged="CmbRazon_SelectionChanged"
                                  Margin="0,0,0,10"
                                  IsHitTestVisible="True"
                                  Focusable="True"
                                  IsTabStop="True"
                                  TabIndex="2"
                                  Panel.ZIndex="99">
                        </ComboBox>

                        <!-- Panel Otros -->
                        <Grid x:Name="PanelOtros" Margin="0,0,0,10" Visibility="Collapsed">
                            <TextBox x:Name="TxtOtroRazon"
                                     Height="44" FontSize="13"
                                     Style="{StaticResource ModernTextBox}"
                                     MaxLength="100"
                                     TextChanged="TxtOtroRazon_TextChanged"/>
                            <TextBlock x:Name="PlaceholderOtros"
                                       Text="Especifique la razón..."
                                       FontSize="13" Foreground="#4B5563"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center" Margin="14,0,0,0"/>
                        </Grid>

                        <TextBlock x:Name="TxtErrorOtros" Text=""
                                   FontSize="11" Foreground="#f87171"
                                   HorizontalAlignment="Left" Margin="2,0,0,8"/>

                        <!-- Botón INGRESAR -->
                        <Button x:Name="BtnIngresar" Content="INGRESAR"
                                Height="50" Margin="0,6,0,0"
                                Style="{StaticResource ModernButton}"
                                Click="BtnIngresar_Click"
                                IsDefault="True"
                                IsHitTestVisible="True"
                                Focusable="True"
                                Panel.ZIndex="99"
                                TabIndex="3"/>

                        <!-- Estado / error -->
                        <TextBlock x:Name="TxtEstado" Text=""
                                   FontSize="13" Foreground="#fbbf24"
                                   HorizontalAlignment="Center" Margin="0,14,0,0"
                                   TextWrapping="Wrap" TextAlignment="Center"/>

                        <!-- Indicador de conexión -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                            <Ellipse x:Name="IndicadorConexion" Width="8" Height="8"
                                     Fill="#ef4444" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtConexion" Text="Desconectado"
                                       FontSize="11" Foreground="#64748B"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ══ PANEL DE SESIÓN ACTIVA ══ -->
            <StackPanel x:Name="PanelSesion" Grid.Row="1"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="Collapsed" Width="340">

                <Border CornerRadius="20" Padding="36,30">
                    <Border.Background>
                        <SolidColorBrush Color="#D928282D"/>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#40FFFFFF"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <StackPanel>
                        <TextBlock Text="✅ Sesión Activa"
                                   FontSize="22" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" Margin="0,0,0,18"/>
                        <TextBlock x:Name="TxtBienvenida" Text=""
                                   FontSize="18" Foreground="White" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                        <TextBlock x:Name="TxtInfoAlumno" Text=""
                                   FontSize="13" Foreground="#94A3B8"
                                   HorizontalAlignment="Center" Margin="0,0,0,28"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                        <Button x:Name="BtnCerrarSesion" Content="CERRAR SESIÓN"
                                Height="46" Style="{StaticResource DangerButton}"
                                Click="BtnCerrarSesion_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Consola de depuración (oculta, Ctrl+B+U para mostrar) -->
            <Border x:Name="PanelDebug" Grid.Row="3" Background="#0a0a1a" BorderBrush="#1E293B" BorderThickness="0,1,0,0" Visibility="Collapsed">
                <ScrollViewer x:Name="DebugScroll"
                              MaxHeight="110" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto" Padding="8,4">
                    <TextBlock x:Name="TxtDebug"
                               FontFamily="Consolas, Courier New" FontSize="11"
                               Foreground="#5af78e" TextWrapping="NoWrap" VerticalAlignment="Top"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
